rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isCreate() {
      return request.method == 'create';
    }

    function isUpdate() {
      return request.method == 'update';
    }

    // --- Validation Blueprints ---
    
    function isValidJob(data) {
      return data.keys().hasAll(['title', 'jdText', 'xrayQuery', 'userId', 'createdAt'])
        && data.keys().size() <= 10
        && data.title is string && data.title.size() <= 200
        && data.jdText is string && data.jdText.size() <= 10000
        && data.xrayQuery is string && data.xrayQuery.size() <= 1000
        && data.userId == request.auth.uid;
    }

    function isValidCandidate(data) {
      return data.keys().hasAll(['title', 'link', 'userId', 'jobId', 'createdAt'])
        && data.title is string
        && data.link is string
        && data.userId == request.auth.uid
        && data.jobId is string;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['subject', 'body', 'candidateId', 'userId', 'createdAt'])
        && data.subject is string
        && data.body is string
        && data.userId == request.auth.uid
        && data.candidateId is string;
    }

    // --- Match Rules ---

    match /jobs/{jobId} {
      allow create: if isSignedIn() && isValidId(jobId) && isValidJob(incoming())
        && incoming().createdAt == request.time;
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isOwner(existing()) && isValidJob(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Update Job Info
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'jdText', 'xrayQuery', 'skills', 'preferred', 'experience', 'keywords'])
        );
      allow delete: if isOwner(existing());

      match /candidates/{candidateId} {
        function parentJobOwned() {
          return get(/databases/$(database)/documents/jobs/$(jobId)).data.userId == request.auth.uid;
        }

        allow create: if isSignedIn() && isValidId(candidateId) && parentJobOwned() && isValidCandidate(incoming())
          && incoming().createdAt == request.time;
        allow get: if isOwner(existing());
        allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow update: if isOwner(existing()) && isValidCandidate(incoming())
          && incoming().userId == existing().userId
          && incoming().jobId == existing().jobId
          && incoming().createdAt == existing().createdAt
          && (
            // Action: Update Candidate Status or Info
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'title', 'link', 'snippet'])
          );
        allow delete: if isOwner(existing());

        match /messages/{messageId} {
          allow create: if isSignedIn() && isValidId(messageId) && parentJobOwned() && isValidMessage(incoming())
            && incoming().createdAt == request.time;
          allow get: if isOwner(existing());
          allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
          allow update: if false; 
          allow delete: if isOwner(existing());
        }
      }
    }
  }
}
